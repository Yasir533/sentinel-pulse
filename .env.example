# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=generate-a-secure-key-here-for-production
JWT_SECRET_KEY=generate-a-secure-jwt-key-here

# Database Configuration
# Default is SQLite for development, can be PostgreSQL for production
DATABASE_URL=sqlite:///sentinel_pulse.db
# DATABASE_URL=postgresql://user:password@localhost:5432/sentinel_pulse

# Celery & Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Mail Configuration (Optional placeholders)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-app-password
MAIL_DEFAULT_SENDER=sentinel-pulse@yourdomain.com

# VirusTotal Configuration
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY

# AbuseIPDB Configuration
ABUSEIPDB_API_KEY=YOUR_ABUSEIPDB_API_KEY

# Sentinel Pulse Public Threat API Key
SENTINEL_API_KEY=sentinel_pulse_api_key_2026

# Production CORS Configuration (Comma-separated list of allowed domains)
# CORS_ALLOWED_ORIGINS=https://sentinelpulse.yourdomain.com,https://api.yourdomain.com
